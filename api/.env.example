NODE_ENV=development
PORT=3001

# Neon: copy the exact connection string from the Neon dashboard (prefer the "pooled" / pooler URL if direct TCP times out).
# If you see connect ETIMEDOUT: check VPN/firewall, resume project in Neon, or try another network.
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis for BullMQ (workers + job enqueue). Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# API-only: set true to skip Redis and avoid connecting at startup (no background jobs until Redis is available).
# The worker process still requires Redis — leave REDIS_DISABLED unset or false when running workers.
# REDIS_DISABLED=true

# Minimum 32 characters in production
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Optional: enables OpenAI for parsing and solving (otherwise placeholders / heuristics run)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Development only: set true once to create/alter tables from Sequelize models (not for production)
SYNC_DB=false

BCRYPT_ROUNDS=12
